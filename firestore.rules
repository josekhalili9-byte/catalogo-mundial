rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: jerseys
    // Document ID: auto-generated
    // Fields:
    //   - team: string (required, < 100 chars)
    //   - type: string (required, in ['Local', 'Visitante', 'Alternativa'])
    //   - price: number (required, > 0)
    //   - imageUrl: string (required, valid URL)
    // ===============================================================

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'josekhalili9@gmail.com';
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*")) && url.size() < 1000000;
    }

    function isValidJersey(data) {
      return data.keys().hasOnly(['team', 'type', 'price', 'imageUrl']) &&
             data.team is string && data.team.size() > 0 && data.team.size() < 100 &&
             data.type in ['Local', 'Visitante', 'Alternativa'] &&
             data.price is number && data.price >= 0 &&
             isValidUrl(data.imageUrl);
    }

    match /jerseys/{jerseyId} {
      // Public read for the catalog
      allow read: if true;
      // Admin write (authenticated via Google with specific email)
      allow create: if isAdmin() && isValidJersey(request.resource.data);
      allow update: if isAdmin() && isValidJersey(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
